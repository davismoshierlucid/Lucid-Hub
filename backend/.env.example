PORT=3001
NODE_ENV=development

# PostgreSQL — use either DATABASE_URL or PG* fields (replace when AWS RDS is provisioned)
DATABASE_URL=placeholder_until_aws_rds_provisioned
# PGHOST=localhost
# PGPORT=5432
# PGUSER=lucid
# PGPASSWORD=lucid
# PGDATABASE=lucid_hub

FRONTEND_ORIGIN=http://localhost:5173

# AWS Cognito (Hosted UI) + Microsoft (Azure AD) federation
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# Required for many server-side authorization code flows
COGNITO_CLIENT_SECRET=
# Hosted UI domain prefix only (no protocol), e.g. my-app.auth.us-east-1.amazoncognito.com
COGNITO_HOSTED_UI_DOMAIN=
# Must match an allowed callback URL on the app client (backend receives the code)
COGNITO_REDIRECT_URI=http://localhost:3001/api/auth/callback
# Optional: Azure AD / Entra provider name configured on the user pool
COGNITO_IDENTITY_PROVIDER=
